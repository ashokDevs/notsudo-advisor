# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/notsudo

# LLM Configuration
# The system uses langchain-openai by default, but can be adapted for others.
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o

# GitHub Integration (Required for PR creation)
GITHUB_TOKEN=ghp_...

# GitHub OAuth App (for "Sign in with GitHub" in the demo UI)
# Register at: https://github.com/settings/applications/new
#   Homepage URL:               http://localhost:8080
#   Authorization callback URL: http://localhost:8080/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# The GitHub repo that fix-PRs are opened against (owner/name):
GITHUB_DEMO_REPO=ashokDevs/notsudo-demo-app
# Base URL the app is served from (must match the OAuth callback host):
APP_BASE_URL=http://localhost:8080
# Secret used to sign the session cookie (any long random string):
SESSION_SECRET=

# Observability
LOG_LEVEL=INFO
