# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/notsudo

# LLM Configuration
# The system uses langchain-openai by default, but can be adapted for others.
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o

# GitHub Integration (Required for PR creation)
GITHUB_TOKEN=ghp_...

# Observability
LOG_LEVEL=INFO
