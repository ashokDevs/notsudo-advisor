# Database (optional — only for `notsudo index` / RAG)
DATABASE_URL=postgresql://user:password@localhost:5432/notsudo

# ── LLM (OpenAI-compatible) ──────────────────────────────────────────────────
# OpenRouter example:
#   OPENAI_API_KEY=sk-or-v1-...
#   OPENAI_API_BASE=https://openrouter.ai/api/v1
#   LLM_MODEL=openai/gpt-4o-mini
# OpenAI example:
#   OPENAI_API_KEY=sk-...
#   LLM_MODEL=gpt-4o
OPENAI_API_KEY=
OPENAI_API_BASE=
LLM_MODEL=gpt-4o
LLM_CHEAP_MODEL=gpt-4o-mini

NOTSUDO_HASH_EMBEDDINGS=1

# ── GitHub write access (need ONE of: OAuth pair OR PAT) ─────────────────────
# PAT (simplest for opening fix PRs):
GITHUB_TOKEN=

# OAuth App (Dashboard "Sign in with GitHub") — BOTH required:
# https://github.com/settings/applications/new
#   Homepage: http://localhost:8080
#   Callback: http://localhost:8080/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

GITHUB_DEMO_REPO=owner/your-repo
# Auto-merge fix PRs after opening (requires merge permission on the repo)
GITHUB_AUTO_MERGE=false
# squash | merge | rebase
GITHUB_MERGE_METHOD=squash

APP_BASE_URL=http://localhost:8080
SESSION_SECRET=change-me-to-a-long-random-string

LOG_LEVEL=INFO
